{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Niro Media",
  "version": "3.0.0",
  "identifier": "com.niromedia.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Niro Media",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "minWidth": 400,
        "minHeight": 300,
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "libmpv-2.dll",
      "shaders/FSR.glsl",
      "shaders/Anime4K_Clamp_Highlights.glsl",
      "shaders/Anime4K_Restore_CNN_S.glsl",
      "shaders/Anime4K_Upscale_CNN_x2_S.glsl"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
